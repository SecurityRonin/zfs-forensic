/target

# Pure-library workspace — the lock is not committed (fleet policy commits
# Cargo.lock only in binary/app repos, so downstream consumers resolve freely).
/Cargo.lock

# Large ZFS oracle images are gitignored — only the small always-on L0 vdev label
# fixture (tests/data/zfs_label0.bin, 256 KiB) and the oracle TEXT ground truth
# (tests/data/README.md) are committed. Re-mint / re-download the full images from
# the recorded commands and point ZFS_ORACLE_IMG / ZFS_TIER1_FREEBSD at them.
# (The FreeBSD ZFS-root partition — ZFS_TIER1_FREEBSD — lives in /tmp, never
# in-tree; these globs are belt-and-suspenders should one be extracted here.)
/tests/data/*.img
/tests/data/*.raw
/tests/data/*.part
/tests/data/*.qcow2
/tests/data/*.xz

# OS / editor cruft.
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
